pipeline {
    agent any
    
    tools {
        maven 'csemaven'
        jdk 'csejava'
    }
    
    stages {
        stage('Checkout') {
            steps {
                // Pulls the latest code from your GitHub repository
                checkout scm
            }
        }
        
        stage('Build & Test') {
            steps {
                dir('edupulse_clean') {
                    // 'verify' runs the build and generates the JaCoCo coverage report
                    bat 'mvn clean verify'
                }
            }
        }

        stage('SonarQube Analysis') {
            steps {
                withSonarQubeEnv('SonarServer') {
                    dir('edupulse_clean') {
                        bat 'mvn sonar:sonar'
                    }
                }
            }
        }
        
        stage('Archive Artifacts') {
            steps {
                // Keep the JAR file in Jenkins for safe keeping
                archiveArtifacts artifacts: 'edupulse_clean/target/*.jar', allowEmptyArchive: true
            }
        }

        stage('Deploy to AWS with Ansible') {
            steps {
                dir('edupulse_clean') {
                    echo 'Executing Ansible via default WSL environment...'
                    /* We removed '-u ubuntu' to avoid the "User not found" error. 
                       WSL will now use your default login automatically.
                    */
                    bat 'wsl bash -c "ANSIBLE_HOST_KEY_CHECKING=False /usr/bin/ansible-playbook -i hosts deploy.yml"'
                }
            }
        }
    }
    
    post {
        success {
            echo 'Congratulations Pinky! The entire pipeline finished successfully.'
            echo 'Your EduPulse app is live at: http://100.31.148.55:8087'
        }
        failure {
            echo 'The pipeline failed. Check the Console Output to see the error details.'
        }
    }
}