pipeline {
    agent any
    
    tools {
        maven 'csemaven'
        jdk 'csejava'
    }
    
    stages {
        stage('Checkout') {
            steps {
                // Pulls the latest code from your GitHub repository
                checkout scm
            }
        }
        
        stage('Build & Test') {
            steps {
                dir('edupulse_clean') {
                    // Running 'verify' instead of 'package' ensures unit tests run 
                    // and JaCoCo generates the coverage report for SonarQube.
                    bat 'mvn clean verify'
                }
            }
        }

        stage('SonarQube Analysis') {
            steps {
                // Ensure 'SonarServer' matches the name in your Jenkins System Configuration
                withSonarQubeEnv('SonarServer') {
                    dir('edupulse_clean') {
                        bat 'mvn sonar:sonar'
                    }
                }
            }
        }
        
        stage('Archive Artifacts') {
            steps {
                // Saves the JAR file inside Jenkins so you have a backup of the build
                archiveArtifacts artifacts: 'edupulse_clean/target/*.jar', allowEmptyArchive: true
            }
        }

        stage('Deploy to AWS with Ansible') {
            steps {
                dir('edupulse_clean') {
                    echo 'Deploying to AWS EC2 Instance via WSL...'
                    // Using the absolute path you found: /usr/bin/ansible-playbook
                    // This ensures Jenkins finds the command every time.
                    bat 'wsl ANSIBLE_HOST_KEY_CHECKING=False /usr/bin/ansible-playbook -i hosts deploy.yml'
                }
            }
        }
    }
    
    post {
        success {
            echo 'Congratulations Pinky! The entire pipeline finished successfully.'
            echo 'Your app should be live at: http://100.31.148.55:8087'
        }
        failure {
            echo 'The pipeline failed. Check the Console Output to see the error details.'
        }
    }
}