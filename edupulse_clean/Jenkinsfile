pipeline {
    agent any
    
    tools {
        maven 'csemaven'
        jdk 'csejava'
    }
    
    stages {
        stage('Checkout') {
            steps {
                checkout scm
            }
        }
        
        stage('Build & Test') {
            steps {
                dir('edupulse_clean') {
                    bat 'mvn clean verify'
                }
            }
        }

        stage('SonarQube Analysis') {
            steps {
                withSonarQubeEnv('SonarServer') {
                    dir('edupulse_clean') {
                        bat 'mvn sonar:sonar'
                    }
                }
            }
        }
        
        stage('Archive Artifacts') {
            steps {
                archiveArtifacts artifacts: 'edupulse_clean/target/*.jar', allowEmptyArchive: true
            }
        }

        stage('Deploy to AWS with Ansible') {
            steps {
                dir('edupulse_clean') {
                    echo 'Executing Ansible via WSL...'
                    
                    // ✅ FIXED COMMAND (NO /usr/bin/bash)
                    bat '''
                    wsl bash -c "cd /mnt/c/ProgramData/Jenkins/.jenkins/workspace/Feedback-Pipeline/edupulse_clean && ANSIBLE_HOST_KEY_CHECKING=False ansible-playbook -i hosts deploy.yml"
                    '''
                }
            }
        }
    }
    
    post {
        success {
            echo 'Congratulations Pinky! The entire pipeline finished successfully.'
            echo 'Your EduPulse app is live at: http://100.31.148.55:8087'
        }
        failure {
            echo 'The pipeline failed. Check the Console Output!'
        }
    }
}