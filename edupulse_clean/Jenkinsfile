pipeline {
    agent any
    
    tools {
        maven 'csemaven'
        jdk 'csejava'
    }
    
    stages {
        stage('Checkout') {
            steps {
                // Pulls the latest code from your GitHub repository
                checkout scm
            }
        }
        
        stage('Build & Test') {
            steps {
                dir('edupulse_clean') {
                    // Running 'verify' ensures tests run and coverage is recorded
                    bat 'mvn clean verify'
                }
            }
        }

        stage('SonarQube Analysis') {
            steps {
                withSonarQubeEnv('SonarServer') {
                    dir('edupulse_clean') {
                        bat 'mvn sonar:sonar'
                    }
                }
            }
        }
        
        stage('Archive Artifacts') {
            steps {
                archiveArtifacts artifacts: 'edupulse_clean/target/*.jar', allowEmptyArchive: true
            }
        }

        stage('Deploy to AWS with Ansible') {
            steps {
                dir('edupulse_clean') {
                    echo 'Executing Ansible via WSL Login Shell...'
                    /* We use '-u ubuntu' to act as your Linux user.
                       We use 'bash -c' to ensure the Linux shell handles the environment variables 
                       and paths correctly, which stops the "not found" error.
                    */
                    bat 'wsl -u ubuntu bash -c "ANSIBLE_HOST_KEY_CHECKING=False /usr/bin/ansible-playbook -i hosts deploy.yml"'
                }
            }
        }
    }
    
    post {
        success {
            echo 'Congratulations Pinky! The entire pipeline finished successfully.'
            echo 'Access your app here: http://100.31.148.55:8087'
        }
        failure {
            echo 'The pipeline failed. Check the Console Output to see the error details.'
        }
    }
}