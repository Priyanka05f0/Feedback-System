pipeline {
    agent any
    
    tools {
        maven 'csemaven'
        jdk 'csejava'
    }
    
    stages {
        stage('Checkout') {
            steps {
                // Pulls the code from your GitHub: https://github.com/Priyanka05f0/Feedback-System.git
                checkout scm
            }
        }
        
        stage('Build & Test') {
            steps {
                // Based on your GitHub, the pom.xml is inside this folder
                dir('edupulse_clean') {
                    bat 'mvn clean verify'
                }
            }
        }

        stage('SonarQube Analysis') {
            steps {
                withSonarQubeEnv('SonarServer') {
                    dir('edupulse_clean') {
                        bat 'mvn sonar:sonar'
                    }
                }
            }
        }
        
        stage('Archive Artifacts') {
            steps {
                archiveArtifacts artifacts: 'edupulse_clean/target/*.jar', allowEmptyArchive: true
            }
        }

        stage('Deploy to AWS with Ansible') {
            steps {
                dir('edupulse_clean') {
                    echo 'Executing Ansible via verified WSL bash path...'
                    /* 1. We use /usr/bin/bash because that's what your system confirmed.
                       2. We use -c to run the Linux command inside quotes.
                       3. We bypass host key checking to avoid the pipeline getting stuck on a "Yes/No" prompt.
                    */
                    bat 'wsl /usr/bin/bash -c "ANSIBLE_HOST_KEY_CHECKING=False /usr/bin/ansible-playbook -i hosts deploy.yml"'
                }
            }
        }
    }
    
    post {
        success {
            echo 'Congratulations Pinky! The entire pipeline finished successfully.'
            echo 'Your EduPulse app is live at: http://100.31.148.55:8087'
        }
        failure {
            echo 'The pipeline failed. Check the Console Output for Build #12!'
        }
    }
}